# Documentation / notes Markdown — ne pas commiter
*.md

# Dépendances
node_modules/
.pnp/
.pnp.js

# Build / cache Next.js
.next/
out/
build/
dist/

# Environnement et secrets — AUCUN .env ne doit etre versionne (ils contiennent
# des secrets : AZURE_AD_CLIENT_SECRET, mots de passe DB, cles de stockage...).
# Fournir les valeurs via le pipeline CI/CD ou un coffre (Key Vault).
.env
.env.*
!.env.example

# Cles privees / certificats exportes — JAMAIS versionnes
privateKey.txt
**/privateKey.txt
*.key.txt
*.pfx

# Certificats HTTPS locaux (mkcert) — ne pas versionner
*.pem
**/*.pem
localhost+*.pem

# Debug / logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Tests / couverture
coverage/
.nyc_output/

# Éditeurs / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Système
.DS_Store
Thumbs.db

# Vercel (si déploiement)
.vercel

# PWA / Service Worker (générés)
**/public/sw.js
**/public/workbox-*.js
**/public/worker-*.js
**/public/swe-worker-*.js

# TypeScript (cache optionnel)
*.tsbuildinfo

# Next.js (fichiers générés)
.next/cache/

#.cursors
.cursors/